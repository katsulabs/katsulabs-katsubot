# 로컬 개발 환경 — cp infra/.env.example infra/.env 후 값 채우기 (커밋 금지)
#
# Gateway: ../katsulabs-ai-gateway/infra/.env 와 동일한 DB·JWT 값을 맞춘다.
# 선행: hyobee-rag-db 컨테이너 기동 (WRTN persistence, 호스트 포트 보통 15433)

# --- chat-api (:8081) ---
# gateway: AI Gateway(:8090) upstream — hyobee-rag-db 대화/메시지
# in-memory: 로컬 스텁 DB | jpa: chat-api 전용 Postgres
SPRING_PROFILES_ACTIVE=gateway
RAG_SERVICE_BASE_URL=http://localhost:8090
RAG_SERVICE_MODE=direct
KATSUBOT_AUTH_DEV_BYPASS=true
# dev-bypass용 JWT — ./scripts/mint-hyobee-dev-jwt.sh 로 재발급 (dev-token 아님)
KATSUBOT_AUTH_DEV_TOKEN=eyJhbGciOiJIUzUxMiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJ0ZXN0MjAyMzAxMjgiLCJjb3JwQ29kZSI6IjAwIiwicGdDb2RlIjoiSCIsInB1Q29kZSI6IkgwMSIsInRlYW1Db2RlIjoiNjVIMDAiLCJyb2xlcyI6WyJST0xFX1VTRVIiLCJST0xFX0FETUlOIl0sImlhdCI6MTc4MjY2NDcxNCwiZXhwIjoyMDk4MDI0NzE0fQ.iFdbCzrdbhTIQLEkNzEvq47W8yWRbt5_nKi9VcijjltDLMIyk-hwIDqqKQ024qyKt3OSTfn83kpJYw4GmMdlbg

# Hyobee SECRET_KEY — legacy/hyobee XtrmConfig.properties (HS512)
# chat-api(KATSUBOT_AUTH_JWT_SECRET)·Gateway(GATEWAY_JWT_SECRET) 공통 — scripts/lib/jwt-env.sh 가 동기화
HYOBEE_JWT_SECRET=yZp3n4W8LkqS1tDbE9mV0rXuA7wC2pTfG5hQ8jR3xU6sNcKdF4vB1zYeH0aMiOwP

# hyobee-admin-db — 로그인 com_user 조회 (레거시 XTRMDB, 호스트 포트 보통 53254)
# URL·비밀번호에 & # 등 특수문자 → 반드시 따옴표
KATSUBOT_ADMIN_DB_URL="jdbc:postgresql://localhost:53254/xtrmvob?tcpKeepAlive=true&applicationName=katsubot-chat-api"
KATSUBOT_ADMIN_DB_USER=XtrmSalesDev
KATSUBOT_ADMIN_DB_PASSWORD="<hyobee-admin-db password>"

# --- AI Gateway (:8090) — docker compose / katsulabs-ai-gateway ---
AI_GATEWAY_REPO=../katsulabs-ai-gateway
GATEWAY_PORT=8090
GATEWAY_WRTN_ENABLED=true
GATEWAY_FLYWAY_ENABLED=false

# hyobee-rag-db (docker port 15433 → postgres:5432)
SPRING_DATASOURCE_URL=jdbc:postgresql://host.docker.internal:15433/wrtn
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=<hyobee-rag-db POSTGRES_PASSWORD>

# Hyobee JWT — HYOBEE_JWT_SECRET 과 동일 (compose·boot 스크립트가 자동 동기화)
# claim: sub=userId, corpCode, pgCode, puCode, teamCode, roles
GATEWAY_DEV_USER_ID=test20230128
GATEWAY_DEV_CORP_CODE=00
GATEWAY_DEV_PG_CODE=H
GATEWAY_DEV_PU_CODE=H01
GATEWAY_DEV_TEAM_CODE=65H00
GATEWAY_DEV_ROLES=ROLE_USER,ROLE_ADMIN

# LLM (선택 — 없으면 stub/ollama)
LLM_API_KEY=ollama
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_MODEL=llama3.2

# --- legacy hyobee (:8080) JVM 오버라이드 참고 ---
# XTRMDB: hyobee-admin-db → localhost:53254 (XtrmConfig.properties 기본값)
# WRTN_BASEURL: http://127.0.0.1:8090 (XtrmConfig.properties, SERVICE_MODE=LOCAL)
