# EC2-2 (Katsubot) — cp infra/poc-ec2/.env.katsubot.example infra/poc-ec2/.env
# 커밋 금지. POC 종료 시 EC2·볼륨 삭제.

# EC2-1 Gateway private IP (예: 10.0.1.10)
RAG_SERVICE_BASE_URL=http://10.0.1.10:8090

SPRING_PROFILES_ACTIVE=gateway
RAG_SERVICE_MODE=direct

# Hyobee JWT — EC2-1 .env 와 동일 값
HYOBEE_JWT_SECRET=change-me-poc-jwt-secret-min-32-chars
KATSUBOT_AUTH_JWT_SECRET=change-me-poc-jwt-secret-min-32-chars

# POC: dev JWT bypass (브라우저 ?jwt= 또는 mint 스크립트)
KATSUBOT_AUTH_DEV_BYPASS=true
# ./scripts/mint-hyobee-dev-jwt.sh infra/poc-ec2/.env 출력값 붙여넣기
KATSUBOT_AUTH_DEV_TOKEN=

KATSUBOT_HTTP_PORT=80
