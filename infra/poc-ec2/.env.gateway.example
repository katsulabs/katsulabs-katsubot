# EC2-1 (Gateway) — cp infra/poc-ec2/.env.gateway.example infra/poc-ec2/.env
# 커밋 금지. POC 종료 시 EC2·볼륨 삭제.

# katsulabs-ai-gateway 클론 경로 (EC2 홈 기준)
AI_GATEWAY_REPO=/home/ec2-user/katsulabs-ai-gateway

# Gateway listen (SG: EC2-2 private IP만 8090 허용)
GATEWAY_BIND=8090

# WRTN Postgres (compose 내 rag-db)
RAG_DB_PASSWORD=change-me-poc-rag-db

# Hyobee JWT — EC2-2 .env 와 동일 값
GATEWAY_JWT_SECRET=change-me-poc-jwt-secret-min-32-chars

GATEWAY_WRTN_ENABLED=true
GATEWAY_FLYWAY_ENABLED=true

GATEWAY_DEV_USER_ID=test20230128
GATEWAY_DEV_CORP_CODE=00
GATEWAY_DEV_PG_CODE=H
GATEWAY_DEV_PU_CODE=H01
GATEWAY_DEV_TEAM_CODE=65H00
GATEWAY_DEV_ROLES=ROLE_USER,ROLE_ADMIN

# LLM — POC: Gemini OpenAI-compatible (Ollama 불필요)
LLM_API_KEY=<google-ai-api-key>
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.0-flash
