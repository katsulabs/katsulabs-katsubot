    <condition property="isWindows">
        <os family="windows" />
    </condition>

    <condition property="isUnix">
        <os family="unix" />
    </condition>

    <target name="maven.path.windows" if="isWindows">
        <property name="maven_home" value="C:/HyosungDev/bin/apache-maven-3.8.6" />
        <property name="maven_task" value="C:/HyosungDev/libs/maven-ant-tasks-2.1.3.jar" />
    </target>

    <target name="maven.path.unix" if="isUnix">
        <property name="maven_home" value="/usr/share/maven" />
        <property name="maven_task" value="/var/jenkins_home/.ant/lib/maven-ant-tasks-2.1.3.jar" />
    </target>

    <target name="maven.task.package" unless="compile.classpath" xmlns:artifact="urn:maven-artifact-ant" depends="maven.path.windows,maven.path.unix">
        <typedef resource="org/apache/maven/artifact/ant/antlib.xml"
                 uri="urn:maven-artifact-ant"
                 classpath="${maven_task}" />
        <artifact:mvn pom="pom.xml" mavenHome="${maven_home}" fork="true">
            <jvmarg value="-Dmaven.multiModuleProjectDirectory=%MAVEN_HOME%" />
            <arg value="clean" />
            <arg value="package" />
            <arg value="war:exploded" /> <arg value="-DskipTests" />
        </artifact:mvn>
    </target>

    <target name="maven.task.clean" unless="compile.classpath" xmlns:artifact="urn:maven-artifact-ant" depends="maven.path.windows,maven.path.unix">
        <typedef resource="org/apache/maven/artifact/ant/antlib.xml"
                 uri="urn:maven-artifact-ant"
                 classpath="${maven_task}" />
        <artifact:mvn pom="pom.xml" mavenHome="${maven_home}" fork="true">
            <jvmarg value="-Dmaven.multiModuleProjectDirectory=%MAVEN_HOME%" />
            <arg value="clean" />
        </artifact:mvn>
    </target>




