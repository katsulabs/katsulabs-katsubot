    <target name="build.dev.step1.archiving" depends="maven.task.package" description="">
        <echo>==================================================</echo>
        <echo>[START] ${app_name} DEV Archiving                 </echo>
        <echo>==================================================</echo>
        <delete file="${war_data}.war" />
        <move file="${war_data}/WEB-INF/classes/application_dev.bak"
              tofile="${war_data}/WEB-INF/classes/application.yml" verbose="true" />
        <move file="${war_data}/WEB-INF/classes/log4j2_dev.bak"
              tofile="${war_data}/WEB-INF/classes/log4j2.xml" verbose="true" />
        <move file="${war_data}/WEB-INF/classes/properties/xs/config/XtrmConfig_dev.bak"
              tofile="${war_data}/WEB-INF/classes/properties/xs/config/XtrmConfig.properties" verbose="true" />
        <delete>
            <fileset dir="${war_data}/WEB-INF/classes" includes="**/*.bak" />
        </delete>
        <war destfile="${war_path}/${app_name}_dev.war" basedir="${war_data}" />
        <echo>==================================================</echo>
        <echo>[END  ] ${app_name} DEV Archiving                 </echo>
        <echo>==================================================</echo>
    </target>

    <target name="build.dev.step2.transfer" description="">
        <echo>==================================================</echo>
        <echo>[START] ${app_name} DEV Transfer                  </echo>
        <echo>==================================================</echo>
        <scp file="${war_path}/${app_name}_dev.war"
             todir="${dev1_was_id}:${dev1_was_pw}@${dev1_was_host}:${dev1_was_path}" port="${dev1_was_port}"
             trust="true" failonerror="true" sftp="true" verbose="false" />
        <sshexec host="${dev1_was_host}" port="${dev1_was_port}" username="${dev1_was_id}" password="${dev1_was_pw}"
                 command="
rm ${dev1_was_path}/${app_name}.war;
mv ${dev1_was_path}/${app_name}_dev.war ${dev1_was_path}/${app_name}.war;
"
                 trust="true" failonerror="false" />
        <echo>==================================================</echo>
        <echo>[END  ] ${app_name} DEV Transfer                  </echo>
        <echo>==================================================</echo>
    </target>

    <target name="build.dev.step3.deploy1" description="">
        <echo>==================================================</echo>
        <echo>[START] ${app_name} DEV Deploy1                   </echo>
        <echo>==================================================</echo>
        <sshexec host="${dev1_was_host}" port="${dev1_was_port}" username="${dev1_was_id}" password="${dev1_was_pw}"
                 command="
${dev1_was_shell}/${dev1_was_stop};
            "
                 trust="true" failonerror="true" verbose="false" />
        <sleep seconds="5" />
        <!-- &amp;&amp; -->
        <sshexec host="${dev1_was_host}" port="${dev1_was_port}" username="${dev1_was_id}" password="${dev1_was_pw}"
                 command="
rm -rf ${dev1_was_path}/${web_name}/WebContent/html;
rm -rf ${dev1_was_path}/${dev1_was_name}/WebContent/META-INF;
rm -rf ${dev1_was_path}/${dev1_was_name}/WebContent/org;
rm -rf ${dev1_was_path}/${dev1_was_name}/WebContent/webapps;
rm -rf ${dev1_was_path}/${dev1_was_name}/WebContent/WEB-INF;
unzip ${dev1_was_path}/${app_name}.war -d ${dev1_was_path}/${dev1_was_name}/WebContent;
cp -arp ${dev2_was_path}/${dev1_was_name}/WebContent/WEB-INF/classes/static/html ${dev1_was_path}/${web_name}/WebContent/html;
"
                 trust="true" failonerror="true" verbose="false" />
        <sleep seconds="5" />
        <sshexec host="${dev1_was_host}" port="${dev1_was_port}" username="${dev1_was_id}" password="${dev1_was_pw}"
                 command="
${dev1_was_shell}/${dev1_was_start};
            "
                 trust="true" failonerror="true" verbose="false" />
        <echo>==================================================</echo>
        <echo>[END  ] ${app_name} DEV Deploy1                   </echo>
        <echo>==================================================</echo>
